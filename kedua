<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistem Member Martabak</title>
    <!-- Library untuk membuat QR Code -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <!-- Library untuk membaca QR Code -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html5-qrcode/2.3.8/html5-qrcode.min.js"></script>
    <style>
        /* CSS Styling */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .header {
            text-align: center;
            color: white;
            margin-bottom: 30px;
        }

        .header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }

        .nav-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-bottom: 30px;
        }

        .nav-btn {
            background-color: rgba(255, 255, 255, 0.1);
            color: white;
            border: 1px solid rgba(255, 255, 255, 0.3);
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 600;
        }

        .nav-btn:hover:not(.active) {
            background-color: rgba(255, 255, 255, 0.2);
            transform: translateY(-2px);
        }

        .nav-btn.active {
            background-color: white;
            color: #667eea;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
        }

        .card {
            background-color: white;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
            margin-bottom: 20px;
        }

        .card h2 {
            color: #4a5568;
            margin-bottom: 20px;
            border-bottom: 2px solid #edf2f7;
            padding-bottom: 10px;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: 500;
            color: #4a5568;
        }

        .form-group input, .form-group select {
            width: 100%;
            padding: 10px;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            box-sizing: border-box;
            transition: border-color 0.3s;
        }

        .form-group input:focus, .form-group select:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 119, 234, 0.2);
        }

        .btn-primary {
            background-color: #667eea;
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: background-color 0.3s, transform 0.1s;
            width: 100%;
        }

        .btn-primary:hover {
            background-color: #5a67d8;
        }

        .btn-primary:disabled {
            background-color: #a0aec0;
            cursor: not-allowed;
        }

        .alert {
            padding: 10px;
            margin-bottom: 15px;
            border-radius: 6px;
            font-weight: 500;
            text-align: center;
        }

        .alert-error {
            background-color: #fed7d7;
            color: #c53030;
            border: 1px solid #c53030;
        }

        .alert-success {
            background-color: #c6f6d5;
            color: #276749;
            border: 1px solid #276749;
        }
        
        /* Layout untuk Admin Dashboard */
        .admin-nav {
            display: flex;
            justify-content: flex-start;
            gap: 10px;
            margin-bottom: 20px;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 10px;
        }

        .admin-nav-btn {
            background-color: transparent;
            color: #4a5568;
            border: none;
            padding: 8px 15px;
            border-radius: 6px 6px 0 0;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: 600;
        }

        .admin-nav-btn.active {
            color: #667eea;
            border-bottom: 3px solid #667eea;
            background-color: #f7fafc;
        }
        
        .grid-3 {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 20px;
        }

        .stat-card {
            background-color: #f7fafc;
            padding: 20px;
            border-radius: 8px;
            text-align: center;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
        }

        .stat-card h3 {
            color: #718096;
            font-size: 1em;
            margin-bottom: 5px;
        }

        .stat-card p {
            font-size: 2em;
            font-weight: 700;
            color: #4a5568;
        }
        
        /* Table Styling */
        .table-responsive {
            overflow-x: auto;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        .data-table th, .data-table td {
            padding: 12px 15px;
            border-bottom: 1px solid #e2e8f0;
            font-size: 0.9em;
        }

        .data-table th {
            background-color: #f7fafc;
            color: #4a5568;
            text-transform: uppercase;
        }

        .data-table tbody tr:hover {
            background-color: #faf5ff;
        }
        
        /* Utility */
        .hidden {
            display: none !important;
        }

        /* Modal Styling */
        .modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.7);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.3s, visibility 0.3s;
        }

        .modal.active {
            opacity: 1;
            visibility: visible;
        }

        .modal-content {
            background-color: white;
            padding: 30px;
            border-radius: 10px;
            max-width: 450px;
            text-align: center;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
            position: relative;
            transform: translateY(-50px);
            transition: transform 0.3s;
        }
        
        .modal.active .modal-content {
            transform: translateY(0);
        }
        
        #qrcode {
            margin: 20px auto;
            display: flex;
            justify-content: center;
            padding: 10px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
        }
        
        #memberInfo {
            text-align: left;
            margin-bottom: 20px;
            background-color: #f7fafc;
            padding: 15px;
            border-radius: 6px;
        }
        
        /* Mobile Responsiveness */
        @media (max-width: 768px) {
            .grid-3 {
                grid-template-columns: 1fr;
            }
            .nav-buttons {
                flex-wrap: wrap;
            }
            .admin-nav {
                overflow-x: auto;
                padding-bottom: 5px;
                white-space: nowrap;
            }
            .data-table th, .data-table td {
                padding: 8px 10px;
            }
        }
        
        #scanner-container {
            width: 100%;
            max-width: 400px;
            margin: 20px auto;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Sistem Member Martabak</h1>
            <p>Kelola data member dan transaksi poin Martabak</p>
        </div>
        
        <div class="nav-buttons" id="main-nav-buttons">
            <!-- Nav buttons akan dirender oleh JavaScript -->
        </div>

        <!-- Hidden iframe untuk Form Submission (Pendaftaran) -->
        <!-- *TIDAK ADA* onload="handleFormSubmit()" DI SINI UNTUK MENGHINDARI REFERENCE ERROR -->
        <iframe name="hidden_iframe" id="hidden_iframe" style="display: none;"></iframe>
        
        <!-- --- HALAMAN HOME (DEFAULT) --- -->
        <div class="page card active" id="home">
            <h2>Selamat Datang</h2>
            <p>Sistem ini membantu Anda mengelola loyalitas pelanggan Martabak. Silakan pilih opsi di atas untuk mendaftar, login member, atau masuk ke panel admin.</p>
        </div>

        <!-- --- HALAMAN REGISTER MEMBER --- -->
        <div class="page card hidden" id="register">
            <h2>Form Pendaftaran Member Baru</h2>
            <form id="registerForm">
                <div class="form-group">
                    <label for="nama">Nama Lengkap</label>
                    <input type="text" id="nama" required>
                </div>
                <div class="form-group">
                    <label for="email">Email (Digunakan untuk Login)</label>
                    <input type="email" id="email" required>
                </div>
                <div class="form-group">
                    <label for="member-password">Password</label>
                    <input type="password" id="member-password" required>
                </div>
                <div class="form-group">
                    <label for="telepon">Nomor Telepon</label>
                    <input type="tel" id="telepon" required>
                </div>
                <div class="form-group">
                    <label for="alamat">Alamat Lengkap</label>
                    <input type="text" id="alamat" required>
                </div>
                <div class="form-group">
                    <label for="kota">Kota</label>
                    <input type="text" id="kota" required>
                </div>
                <div class="form-group">
                    <label for="kodePos">Kode Pos</label>
                    <input type="text" id="kodePos" required>
                </div>
                <button type="submit" class="btn-primary">Daftar Sekarang</button>
            </form>
        </div>
        
        <!-- --- HALAMAN MEMBER LOGIN --- -->
        <div class="page card hidden" id="member-login">
            <h2>Member Login</h2>
            <div class="alert alert-error hidden" id="member-login-alert"></div>
            <div class="form-group">
                <label for="member-login-identifier">Email atau ID Member</label>
                <input type="text" id="member-login-identifier" required>
            </div>
            <div class="form-group">
                <label for="member-login-password">Password</label>
                <input type="password" id="member-login-password" required>
            </div>
            <button class="btn-primary" onclick="memberLogin()">Login</button>
        </div>

        <!-- --- HALAMAN ADMIN LOGIN --- -->
        <div class="page card hidden" id="admin-login">
            <h2>Admin Login</h2>
            <div class="alert alert-error hidden" id="admin-login-alert"></div>
            <div class="form-group">
                <label for="admin-username">Username</label>
                <input type="text" id="admin-username" required>
            </div>
            <div class="form-group">
                <label for="admin-password">Password</label>
                <input type="password" id="admin-password" required>
            </div>
            <button class="btn-primary" onclick="adminLogin()">Login</button>
        </div>
        
        <!-- --- HALAMAN MEMBER DASHBOARD --- -->
        <div class="page card hidden" id="member-dashboard">
            <h2>Dashboard Member</h2>
            <div class="grid-3">
                <div class="stat-card">
                    <h3>Total Poin Anda</h3>
                    <p id="memberTotalPoin">0</p>
                </div>
                <div class="stat-card" style="background-color: #feebc8;">
                    <h3>Dapat Ditukar (250/Martabak)</h3>
                    <p id="exchangeCount">0</p>
                </div>
                <div class="stat-card" style="background-color: #e6fffa;">
                    <h3>Info Akun</h3>
                    <p style="font-size: 1em; font-weight: normal; color: #4a5568;" id="memberIdDisplay">Loading...</p>
                </div>
            </div>
            <div class="card" style="text-align: center;">
                 <h3>QR Code Member Anda</h3>
                 <p style="color: #718096; font-size: 0.9em; margin-bottom: 15px;">Tunjukkan ini pada kasir saat melakukan transaksi.</p>
                 <div id="member-dashboard-qrcode" style="margin: 0 auto; width: 150px;"></div>
            </div>
        </div>

        <!-- --- HALAMAN ADMIN DASHBOARD --- -->
        <div class="page card hidden" id="admin-dashboard">
            <h2>Panel Admin Martabak</h2>
            
            <div class="nav-buttons admin-nav">
                <button class="nav-btn admin-nav-btn active" id="nav-btn-members" onclick="showAdminSection('members')">Data Member</button>
                <button class="nav-btn admin-nav-btn" id="nav-btn-transactions" onclick="showAdminSection('transactions')">Riwayat Transaksi</button>
                <button class="nav-btn admin-nav-btn" id="nav-btn-scan" onclick="showAdminSection('scan')">Input Transaksi</button>
            </div>

            <!-- Bagian Data Member -->
            <div class="admin-section" id="admin-members">
                <div class="grid-3">
                    <div class="stat-card">
                        <h3>Total Member</h3>
                        <p id="totalMembers">0</p>
                    </div>
                </div>
                <div class="form-group" style="max-width: 400px;">
                    <label for="searchMember">Cari Member (ID, Nama, Email, Telp)</label>
                    <input type="text" id="searchMember" placeholder="Ketik untuk mencari...">
                </div>
                <div class="table-responsive">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>ID Member</th>
                                <th>Nama</th>
                                <th>Email</th>
                                <th>Telepon</th>
                                <th>Poin</th>
                                <th>Tgl Daftar</th>
                            </tr>
                        </thead>
                        <tbody id="memberTableBody">
                            <tr><td colspan="6" style="text-align:center;">Memuat data...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Bagian Riwayat Transaksi -->
            <div class="admin-section hidden" id="admin-transactions">
                <div class="grid-3">
                    <div class="stat-card">
                        <h3>Total Transaksi</h3>
                        <p id="totalTransactions">0</p>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>ID Transaksi</th>
                                <th>Waktu</th>
                                <th>ID Member</th>
                                <th>Nama Member</th>
                                <th>Produk</th>
                                <th>Jumlah</th>
                                <th>Total Harga</th>
                                <th>Poin +/-</th>
                                <th>Poin Akhir</th>
                                <th>Tipe</th>
                            </tr>
                        </thead>
                        <tbody id="transactionTableBody">
                            <tr><td colspan="10" style="text-align:center;">Memuat data...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Bagian Scan/Input Transaksi -->
            <div class="admin-section hidden" id="admin-scan">
                <h3>1. Pilih Member</h3>
                
                <div class="nav-buttons" style="margin-bottom: 20px;">
                    <button class="btn-primary" style="width: 200px;" onclick="startScanner()">Scan QR Code</button>
                    <button class="btn-primary" style="width: 200px; background-color: #48bb78;" onclick="showManualSelect()">Pilih Manual</button>
                </div>
                
                <!-- Container Scanner -->
                <div id="scanner-container" class="hidden">
                    <p style="text-align: center; color: #4a5568; margin-bottom: 10px;">Arahkan kamera ke QR Code Member.</p>
                    <div id="reader" style="width: 100%;"></div>
                </div>

                <!-- Container Pilih Manual -->
                <div id="manual-select-container" class="card hidden">
                    <h3>Pilih Member dari Daftar</h3>
                    <div class="form-group">
                        <select id="memberSelect" onchange="selectMemberManual()">
                            <option value="">-- Memuat daftar member --</option>
                        </select>
                    </div>
                </div>

                <!-- Container Input Transaksi -->
                <div id="transaction-container" class="card hidden">
                    <h3 style="color: #667eea; margin-bottom: 15px;">2. Konfirmasi Transaksi</h3>
                    <div id="member-info-trx" style="margin-bottom: 15px;">
                        <p><strong>Member ID:</strong> <span id="selectedMemberId"></span></p>
                        <p><strong>Nama:</strong> <span id="selectedMemberName"></span></p>
                        <p><strong>Poin Saat Ini:</strong> <span id="selectedMemberPoints" style="font-weight: bold; color: #48bb78;"></span></p>
                    </div>

                    <div class="form-group">
                        <label for="transactionType">Tipe Transaksi</label>
                        <select id="transactionType" onchange="updateTransactionForm()">
                            <option value="PEMBELIAN_POIN">Pembelian (Dapat Poin)</option>
                            <option value="TUKAR_POIN">Tukar Poin (Kurangi 250 Poin)</option>
                            <option value="MANUAL_TAMBAH">Manual: Tambah Poin</option>
                            <option value="MANUAL_KURANG">Manual: Kurang Poin</option>
                        </select>
                    </div>
                    
                    <!-- Fields untuk PEMBELIAN_POIN -->
                    <div id="purchaseFields" class="form-group">
                        <div class="form-group">
                             <label for="jumlahItem">Jumlah Item (Misal: Martabak)</label>
                             <input type="number" id="jumlahItem" min="1" value="1">
                        </div>
                        <div class="form-group">
                            <label for="totalHarga">Total Harga (Rp)</label>
                            <input type="number" id="totalHarga" placeholder="Masukkan total harga" required>
                        </div>
                    </div>
                    
                    <!-- Fields untuk MANUAL -->
                    <div id="manualPoinField" class="form-group hidden">
                        <label for="manualPoinValue">Nilai Poin (Misal: 50 atau -50)</label>
                        <input type="number" id="manualPoinValue" required>
                    </div>

                    <button class="btn-primary" onclick="submitTransaction()">Proses Transaksi</button>
                </div>
            </div>

        </div>
    </div>
    
    <!-- Modal Sukses Pendaftaran -->
    <div class="modal" id="successModal">
        <div class="modal-content">
            <h2 style="color: #48bb78;">✅ Pendaftaran Berhasil!</h2>
            <div id="qrcode"></div>
            <div id="memberInfo"></div>
            <div style="display: flex; gap: 10px;">
                <button class="btn-primary" style="background-color: #48bb78;" onclick="downloadQR()">Download QR</button>
                <button class="btn-primary" onclick="closeModal()">Selesai & Login</button>
            </div>
        </div>
    </div>

    <!-- PENTING: SCRIPT INI HARUS BERADA DI BAWAH SEMUA HTML -->
    <script>
        // ====================================================================
        // --- KONFIGURASI URL APPS SCRIPT (MOHON GANTI DENGAN URL ANDA!) ---
        // ====================================================================
        const MEMBER_SHEET_URL = 'https://script.google.com/macros/s/AKfycbxRmVcSqMxaaa5c3JgDDF8PaEuTyJZJ1Q58tLsFb_ww1k3YxXsZbypDWzdhQC6Fi1KK/exec'; // GANTI INI!
        const TRANSACTION_SHEET_URL = 'https://script.google.com/macros/s/AKfycbyETuMz9nkNFhooJRViX9NfVFRZRdBEnvSC5iG5VL1DMTwz1MQpXCVBODh2R52J7oqv/exec'; // GANTI INI!

        // --- KONFIGURASI AKUN ADMIN ---
        const ADMIN_USERNAME = 'martabak'; 
        const ADMIN_PASSWORD = '189189';
        const AUTH_KEY = 'martabak_auth';

        let membersData = [];
        let transactionsData = [];
        let selectedMember = null;
        let html5QrCode = null;
        let currentUser = JSON.parse(localStorage.getItem(AUTH_KEY));

        // --- AUTH & SESSION MANAGEMENT ---

        function checkSession() {
            currentUser = JSON.parse(localStorage.getItem(AUTH_KEY));
            renderNavButtons();
            
            if (currentUser) {
                if (currentUser.role === 'admin') {
                    showPage('admin-dashboard');
                    loadMembers(); // Muat data di awal
                    loadTransactions(); // Muat data di awal
                } else if (currentUser.role === 'member') {
                    showPage('member-dashboard');
                    loadMemberDashboard(currentUser.memberId);
                }
            } else {
                showPage('home');
            }
        }

        function renderNavButtons() {
            const navContainer = document.getElementById('main-nav-buttons');
            navContainer.innerHTML = '';

            if (currentUser) {
                const dashboardId = currentUser.role === 'admin' ? 'admin-dashboard' : 'member-dashboard';
                const dashboardText = currentUser.role === 'admin' ? 'Dashboard Admin' : 'Dashboard Member';

                navContainer.innerHTML = `
                    <button class="nav-btn active" onclick="showPage('${dashboardId}')">${dashboardText}</button>
                    <button class="nav-btn" onclick="appLogout()">Logout</button>
                `;
                if (currentUser.role === 'admin') showAdminSection('members');
            } else {
                navContainer.innerHTML = `
                    <button class="nav-btn active" onclick="showPage('home')">Beranda</button>
                    <button class="nav-btn" onclick="showPage('register')">Daftar Member</button>
                    <button class="nav-btn" onclick="showPage('member-login')">Member Login</button>
                    <button class="nav-btn" onclick="showPage('admin-login')">Admin Login</button>
                `;
            }
        }
        
        async function memberLogin() {
            const identifier = document.getElementById('member-login-identifier').value.trim();
            const password = document.getElementById('member-login-password').value;
            const alertElement = document.getElementById('member-login-alert');
            alertElement.classList.add('hidden');

            if (!identifier || !password) {
                alertElement.textContent = 'Masukkan Email/ID Member dan Password.';
                alertElement.classList.remove('hidden');
                return;
            }

            try {
                // Menggunakan POST/JSON, yang memerlukan CORS handling di Apps Script (sudah ada)
                const response = await fetch(MEMBER_SHEET_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        action: 'memberLogin',
                        identifier: identifier, 
                        password: password 
                    })
                });
                
                // Cek status response (penting untuk error jaringan/CORS)
                if (!response.ok) {
                    throw new Error(`Koneksi Gagal (Status: ${response.status} ${response.statusText}).`);
                }
                
                const result = await response.json();
                
                if (result.status === 'success') {
                    currentUser = { role: 'member', memberId: result.memberId };
                    localStorage.setItem(AUTH_KEY, JSON.stringify(currentUser));
                    checkSession();
                    document.getElementById('member-login-identifier').value = '';
                    document.getElementById('member-login-password').value = '';
                } else {
                    alertElement.textContent = 'Login gagal. Email/ID Member atau Password salah.';
                    alertElement.classList.remove('hidden');
                }
            } catch (error) {
                console.error('Login error (CORS/Server):', error);
                alertElement.textContent = `Terjadi kesalahan: ${error.message}. (Pastikan Apps Script MEMBER di-deploy dengan akses 'Anyone').`;
                alertElement.classList.remove('hidden');
            }
        }

        function adminLogin() {
            const username = document.getElementById('admin-username').value;
            const password = document.getElementById('admin-password').value;
            const alertElement = document.getElementById('admin-login-alert');
            alertElement.classList.add('hidden');

            if (username === ADMIN_USERNAME && password === ADMIN_PASSWORD) {
                currentUser = { role: 'admin', username: ADMIN_USERNAME };
                localStorage.setItem(AUTH_KEY, JSON.stringify(currentUser));
                checkSession();
                document.getElementById('admin-username').value = '';
                document.getElementById('admin-password').value = '';
            } else {
                alertElement.textContent = 'Username atau password salah!';
                alertElement.classList.remove('hidden');
            }
        }

        function appLogout() {
            localStorage.removeItem(AUTH_KEY);
            currentUser = null;
            checkSession();
            // Clear inputs
            document.getElementById('member-login-identifier').value = '';
            document.getElementById('member-login-password').value = '';
            document.getElementById('admin-username').value = '';
            document.getElementById('admin-password').value = '';
            showPage('home'); 
        }

        // --- NAVIGATION & VIEWS ---

        function showPage(pageId) {
            // Sembunyikan semua halaman
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            // Tampilkan halaman yang diminta
            document.getElementById(pageId).classList.add('active');
            
            // Atur tombol navigasi
            document.querySelectorAll('#main-nav-buttons .nav-btn').forEach(b => b.classList.remove('active'));
            const clickedBtn = Array.from(document.querySelectorAll('#main-nav-buttons .nav-btn')).find(btn => btn.textContent.toLowerCase().includes(pageId.replace('-', ' ').split(' ')[0]));
            if(clickedBtn) clickedBtn.classList.add('active');
            
            if (pageId === 'admin-dashboard') {
                showAdminSection('members'); 
            }
        }

        function showAdminSection(section) {
            document.querySelectorAll('.admin-section').forEach(s => s.classList.add('hidden'));
            document.querySelectorAll('#admin-dashboard .nav-buttons .nav-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('admin-' + section).classList.remove('hidden');
            
            const sectionBtn = document.getElementById(`nav-btn-${section}`);
            if(sectionBtn) sectionBtn.classList.add('active');

            if (section === 'members') loadMembers();
            if (section === 'transactions') loadTransactions();
            if (section === 'scan') {
                loadMemberSelect(); 
                document.getElementById('transaction-container').classList.add('hidden'); 
                stopScanner();
            }
        }
        
        // --- REGISTER MEMBER (MENGGUNAKAN FORM.SUBMIT()) ---
        
        // Fungsi ini dipanggil saat iframe menerima balasan dari Apps Script
        function handleFormSubmit() {
            const iframe = document.getElementById('hidden_iframe');
            
            // Cek apakah iframe berisi konten (hanya setelah form disubmit)
            // Cek URL untuk memastikan respons Apps Script
            if (iframe.src === 'about:blank' || !iframe.src.startsWith('https://script.google.com/macros')) return;
            
            const submitBtn = document.querySelector('#registerForm button[type="submit"]');
            submitBtn.textContent = 'Daftar Sekarang';
            submitBtn.disabled = false;
            
            // Ambil data yang tersimpan sementara
            const tempFormData = JSON.parse(sessionStorage.getItem('tempFormData'));
            sessionStorage.removeItem('tempFormData');
            
            if (!tempFormData) {
                 // Jika tidak ada data tersimpan, kemungkinan kegagalan di Apps Script
                 return;
            }

            // Tampilkan Modal Sukses
            document.getElementById('qrcode').innerHTML = '';
            new QRCode(document.getElementById('qrcode'), { text: tempFormData.memberId, width: 200, height: 200 });
            document.getElementById('memberInfo').innerHTML = `
                <p><strong>Member ID:</strong> ${tempFormData.memberId}</p>
                <p><strong>Nama:</strong> ${tempFormData.nama}</p>
                <p><strong>Email:</strong> ${tempFormData.email}</p>
                <p style="margin-top: 15px; color: #667eea;">Silakan gunakan Email/Password untuk Login.</p>
            `;

            document.getElementById('successModal').classList.add('active');
            document.getElementById('registerForm').reset();
            
            // Reload data member di admin jika sedang aktif
            if (currentUser && currentUser.role === 'admin') loadMembers();
            
            // Reset iframe src untuk persiapan submit berikutnya
            iframe.src = 'about:blank'; 
        }

        document.getElementById('registerForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const submitBtn = e.target.querySelector('button[type="submit"]');
            submitBtn.textContent = 'Mendaftar...';
            submitBtn.disabled = true;

            const memberId = 'MBR' + Date.now().toString().slice(-8); 
            const formData = {
                memberId: memberId,
                nama: document.getElementById('nama').value,
                email: document.getElementById('email').value,
                password: document.getElementById('member-password').value, 
                telepon: document.getElementById('telepon').value,
                alamat: document.getElementById('alamat').value,
                kota: document.getElementById('kota').value,
                kodePos: document.getElementById('kodePos').value,
                tanggalDaftar: new Date().toLocaleString('id-ID'),
                qrCodeUrl: memberId,
                totalPoin: 0 
            };
            
            // Simpan data di sessionStorage untuk ditampilkan setelah berhasil
            sessionStorage.setItem('tempFormData', JSON.stringify(formData));

            // Kirim data menggunakan Form POST ke Apps Script Member
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = MEMBER_SHEET_URL;
            form.target = 'hidden_iframe';
            
            // Tambahkan semua data sebagai input tersembunyi
            Object.keys(formData).forEach(key => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = key;
                input.value = formData[key];
                form.appendChild(input);
            });
            
            document.body.appendChild(form);
            form.submit(); // Kirim formulir
            document.body.removeChild(form); // Hapus formulir sementara
            
            // Iframe akan memanggil handleFormSubmit() setelah Apps Script selesai merespon
        });

        // --- MEMBER DASHBOARD LOGIC ---
        async function loadMemberDashboard(memberId) {
            await loadMembers(); 
            const member = membersData.find(m => m.memberId === memberId);
            
            if (member) {
                const currentPoin = parseInt(member.totalPoin) || 0;
                document.getElementById('memberTotalPoin').textContent = currentPoin;
                document.getElementById('memberIdDisplay').textContent = `Member ID: ${memberId} | Email: ${member.email}`;
                document.getElementById('exchangeCount').textContent = Math.floor(currentPoin / 250);

                document.getElementById('member-dashboard-qrcode').innerHTML = '';
                new QRCode(document.getElementById('member-dashboard-qrcode'), {
                    text: memberId,
                    width: 150,
                    height: 150
                });
            }
        }

        // --- ADMIN DASHBOARD LOGIC (MEMBER TABLE) ---
        
        async function loadMembers() {
            try {
                // Menggunakan fetch/GET, yang memerlukan CORS handling di Apps Script (sudah ada)
                const response = await fetch(MEMBER_SHEET_URL);
                
                if (!response.ok) {
                    throw new Error(`Gagal koneksi (Status: ${response.status} ${response.statusText})`);
                }
                
                membersData = await response.json();

                if (membersData.error) throw new Error(membersData.error);

                document.getElementById('totalMembers').textContent = membersData.length;

                // Sortir berdasarkan Poin
                membersData.sort((a, b) => (parseInt(b.totalPoin) || 0) - (parseInt(a.totalPoin) || 0));

                const tbody = document.getElementById('memberTableBody');
                tbody.innerHTML = '';
                
                const search = document.getElementById('searchMember').value.toLowerCase().trim();
                
                const filteredMembers = membersData.filter(member => 
                    !search || 
                    (member.memberId && String(member.memberId).toLowerCase().includes(search)) ||
                    (member.nama && String(member.nama).toLowerCase().includes(search)) ||
                    (member.email && String(member.email).toLowerCase().includes(search)) ||
                    (member.telepon && String(member.telepon).includes(search))
                );


                filteredMembers.forEach(member => {
                    const totalPoin = parseInt(member.totalPoin) || 0; 
                    const row = tbody.insertRow();
                    row.innerHTML = `
                        <td>${member.memberId || '-'}</td>
                        <td>${member.nama || '-'}</td>
                        <td>${member.email || '-'}</td>
                        <td>${member.telepon || '-'}</td>
                        <td><strong>${totalPoin}</strong></td>
                        <td>${member.tanggalDaftar || '-'}</td>
                    `;
                });
            } catch (error) {
                console.error('Error loading members (Cek Apps Script Member dan URL):', error);
                document.getElementById('memberTableBody').innerHTML = `<tr><td colspan="6" style="text-align:center; color:red;">Gagal memuat data member. ${error.message}</td></tr>`;
            }
        }
        
        document.getElementById('searchMember').addEventListener('input', loadMembers);

        // --- ADMIN DASHBOARD LOGIC (TRANSACTION INPUT) ---
        
        function loadMemberSelect() {
            const select = document.getElementById('memberSelect');
            select.innerHTML = '<option value="">-- Pilih Member --</option>';
            // Urutkan berdasarkan nama
            membersData.sort((a, b) => (a.nama || '').localeCompare(b.nama || '')); 
            membersData.forEach(member => {
                select.innerHTML += `<option value="${member.memberId}">${member.nama || '-'} (${member.memberId})</option>`;
            });
        }

        function showManualSelect() {
            document.getElementById('manual-select-container').classList.remove('hidden');
            document.getElementById('scanner-container').classList.add('hidden');
            document.getElementById('transaction-container').classList.add('hidden');
            stopScanner();
        }

        function selectMemberManual() {
            const memberId = document.getElementById('memberSelect').value;
            if (!memberId) {
                document.getElementById('transaction-container').classList.add('hidden');
                return;
            }
            const member = membersData.find(m => m.memberId === memberId);
            showTransactionForm(member);
        }

        // QR Scanner
        function startScanner() {
            document.getElementById('scanner-container').classList.remove('hidden');
            document.getElementById('manual-select-container').classList.add('hidden');
            document.getElementById('transaction-container').classList.add('hidden');

            // Hentikan scanner lama jika ada
            stopScanner();
            
            html5QrCode = new Html5Qrcode("reader");
            
            // Cek ketersediaan kamera
            Html5Qrcode.getCameras().then(devices => {
                if (devices && devices.length) {
                    html5QrCode.start(
                        { deviceId: { exact: devices[0].id } }, // Ambil kamera pertama
                        { fps: 10, qrbox: 250 },
                        onScanSuccess
                    ).catch(err => {
                        alert('Error saat memulai kamera: ' + err);
                    });
                } else {
                    alert('Tidak ada kamera ditemukan.');
                }
            }).catch(err => {
                alert('Tidak dapat mengakses kamera: ' + err);
            });
        }

        function onScanSuccess(decodedText) {
            stopScanner();
            const member = membersData.find(m => m.memberId === decodedText);
            if (member) {
                showTransactionForm(member);
            } else {
                alert('Member tidak ditemukan!');
                document.getElementById('scanner-container').classList.add('hidden');
                showManualSelect(); // Kembali ke pilihan manual
            }
        }

        function stopScanner() {
            if (html5QrCode && html5QrCode.isScanning) {
                html5QrCode.stop().then(() => {
                    document.getElementById('scanner-container').classList.add('hidden');
                }).catch(err => {
                    console.error("Error stopping scanner:", err);
                    document.getElementById('scanner-container').classList.add('hidden');
                });
            }
        }

        function showTransactionForm(member) {
            selectedMember = member;
            document.getElementById('selectedMemberId').textContent = member.memberId;
            document.getElementById('selectedMemberName').textContent = member.nama;
            document.getElementById('selectedMemberPoints').textContent = parseInt(member.totalPoin) || 0;
            document.getElementById('transaction-container').classList.remove('hidden');
            document.getElementById('manual-select-container').classList.add('hidden');
            document.getElementById('scanner-container').classList.add('hidden');
            
            document.getElementById('transactionType').value = 'PEMBELIAN_POIN';
            document.getElementById('jumlahItem').value = '1';
            document.getElementById('totalHarga').value = '';
            document.getElementById('manualPoinValue').value = '';
            updateTransactionForm();
        }

        function updateTransactionForm() {
            const type = document.getElementById('transactionType').value;
            const purchaseFields = document.getElementById('purchaseFields');
            const manualPoinField = document.getElementById('manualPoinField');
            
            purchaseFields.classList.add('hidden');
            manualPoinField.classList.add('hidden');

            if (type === 'PEMBELIAN_POIN') {
                purchaseFields.classList.remove('hidden');
            } else if (type === 'TUKAR_POIN') {
                // Di sini Anda bisa menambahkan logika atau konfirmasi tambahan
            } else if (type === 'MANUAL_TAMBAH' || type === 'MANUAL_KURANG') {
                manualPoinField.classList.remove('hidden');
                document.getElementById('manualPoinValue').value = (type === 'MANUAL_TAMBAH') ? 50 : -50; 
            }
        }

        async function submitTransaction() {
            if (!selectedMember) return;

            const transactionType = document.getElementById('transactionType').value;
            const currentPoin = parseInt(selectedMember.totalPoin) || 0;
            let poinChange = 0;
            let totalHarga = 0;
            let jumlahItem = 0;
            let produk = 'Martabak';

            // 1. Calculate Poin Change and Get Data
            if (transactionType === 'PEMBELIAN_POIN') {
                jumlahItem = parseInt(document.getElementById('jumlahItem').value) || 0;
                totalHarga = parseInt(document.getElementById('totalHarga').value) || 0;
                if (!jumlahItem || totalHarga <= 0 || isNaN(totalHarga)) { 
                    alert('Lengkapi data Jumlah Item dan Total Harga yang valid!'); 
                    return; 
                }
                poinChange = jumlahItem * 5; // Asumsi: 5 poin per item
                produk = 'Pembelian Martabak';
            } else if (transactionType === 'TUKAR_POIN') {
                poinChange = -250;
                produk = 'Tukar Martabak Gratis (250 Poin)';
                jumlahItem = 1;
            } else if (transactionType === 'MANUAL_TAMBAH' || transactionType === 'MANUAL_KURANG') {
                poinChange = parseInt(document.getElementById('manualPoinValue').value) || 0;
                produk = (poinChange >= 0) ? `Manual Tambah Poin (${poinChange})` : `Manual Kurang Poin (${poinChange})`;
                jumlahItem = 1;
                if (poinChange === 0 || isNaN(poinChange)) {
                     alert('Masukkan nilai poin yang valid untuk transaksi manual.'); 
                    return; 
                }
            }
            
            const totalPoinBaru = currentPoin + poinChange;

            // 2. Safety Checks
            if (transactionType !== 'PEMBELIAN_POIN' && totalPoinBaru < 0) {
                alert(`Poin member (${currentPoin}) tidak cukup untuk operasi ini (${poinChange}). Transaksi dibatalkan.`);
                return;
            }
            if (transactionType === 'TUKAR_POIN' && currentPoin < 250) {
                alert(`Poin member (${currentPoin}) kurang dari 250 untuk penukaran martabak gratis! Transaksi dibatalkan.`);
                return;
            }

            const submitBtn = document.querySelector('#transaction-container button.btn-primary');
            const originalText = submitBtn.textContent;
            submitBtn.textContent = 'Memproses...';
            submitBtn.disabled = true;

            const transactionData = {
                transactionId: 'TRX' + Date.now().toString().slice(-10),
                tanggalWaktu: new Date().toLocaleString('id-ID'),
                memberId: selectedMember.memberId,
                namaMember: selectedMember.nama,
                produk: produk,
                jumlahItem: jumlahItem,
                totalHarga: totalHarga,
                poinDidapat: poinChange,
                totalPoinSekarang: totalPoinBaru, 
                tipeTransaksi: transactionType.replace('_', ' '),
                action: 'addTransaction' 
            };
            
            // 3. Update Poin di Apps Script Member
            try {
                const updatePoinRes = await fetch(MEMBER_SHEET_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        action: 'updatePoin',
                        memberId: selectedMember.memberId, 
                        newTotalPoin: totalPoinBaru
                    })
                });
                const updatePoinResult = await updatePoinRes.json();
                
                if (updatePoinResult.status !== 'success') {
                    throw new Error('Gagal update poin member. ' + (updatePoinResult.message || ''));
                }

            } catch (error) {
                 alert('Error saat Update Poin: ' + error.message + '. Transaksi dibatalkan.');
                 submitBtn.textContent = originalText;
                 submitBtn.disabled = false;
                 return;
            }

            // 4. Kirim Data Transaksi ke Apps Script Transaksi
            try {
                const addTrxRes = await fetch(TRANSACTION_SHEET_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(transactionData)
                });
                const addTrxResult = await addTrxRes.json();
                
                if (addTrxResult.status !== 'success') {
                    // Jika transaksi gagal dicatat, kembalikan poin lama
                    throw new Error('Gagal menyimpan transaksi. Poin member sudah terlanjur terupdate, tolong cek Apps Script Transaksi.');
                }
                
                alert(`✅ Transaksi ${transactionData.tipeTransaksi} Berhasil!\n\n` +
                      `Poin: ${poinChange > 0 ? '+' : ''}${poinChange}\n` +
                      `Total poin sekarang: ${totalPoinBaru}`);

                // Reset
                document.getElementById('transaction-container').classList.add('hidden');
                selectedMember = null;

                // Reload data
                await loadMembers();
                await loadTransactions();
            } catch (error) {
                 alert('Error saat Simpan Transaksi: ' + error.message);
            }
            
            submitBtn.textContent = originalText;
            submitBtn.disabled = false;
        }

        // --- ADMIN DASHBOARD LOGIC (TRANSACTION HISTORY) ---
        async function loadTransactions() {
            try {
                // Menggunakan fetch/GET, yang memerlukan CORS handling di Apps Script (sudah ada)
                const response = await fetch(TRANSACTION_SHEET_URL);
                
                if (!response.ok) {
                    throw new Error(`Gagal koneksi (Status: ${response.status} ${response.statusText})`);
                }
                
                transactionsData = await response.json();

                if (transactionsData.error) throw new Error(transactionsData.error);


                document.getElementById('totalTransactions').textContent = transactionsData.length;

                const tbody = document.getElementById('transactionTableBody');
                tbody.innerHTML = '';

                // Reverse untuk menampilkan transaksi terbaru di atas
                transactionsData.reverse().forEach(trx => {
                    const poinVal = parseInt(trx.poinDidapat) || 0;
                    const totalHarga = parseInt(trx.totalHarga) || 0;
                    const totalPoinSekarang = parseInt(trx.totalPoinSekarang) || 0;
                    
                    const row = tbody.insertRow();
                    row.innerHTML = `
                        <td>${trx.transactionId || '-'}</td>
                        <td>${trx.tanggalWaktu || '-'}</td>
                        <td>${trx.memberId || '-'}</td>
                        <td>${trx.namaMember || '-'}</td>
                        <td>${trx.produk || '-'}</td>
                        <td>${trx.jumlahItem || 0}</td>
                        <td>Rp ${totalHarga.toLocaleString('id-ID')}</td>
                        <td><strong style="color: ${poinVal >= 0 ? 'green' : 'red'};">${poinVal > 0 ? '+' : ''}${poinVal}</strong></td>
                        <td>${totalPoinSekarang}</td>
                        <td>${trx.tipeTransaksi || '-'}</td>
                    `;
                });
            } catch (error) {
                console.error('Error loading transactions (Cek Apps Script Transaksi dan URL):', error);
                document.getElementById('transactionTableBody').innerHTML = `<tr><td colspan="10" style="text-align:center; color:red;">Gagal memuat data transaksi. Cek Apps Script Transaksi dan URL.</td></tr>`;
            }
        }

        // --- UTILITY ---
        function downloadQR() {
            const canvas = document.querySelector('#successModal #qrcode canvas, #member-dashboard-qrcode canvas');
            if (!canvas) { alert('QR Code belum dibuat!'); return; }
            const url = canvas.toDataURL('image/png');
            const link = document.createElement('a');
            link.download = 'member-qr-code.png';
            // Gunakan memberId sebagai nama file jika di dashboard member
            const fileName = currentUser && currentUser.role === 'member' ? `${currentUser.memberId}_qr.png` : 'member-qr-code.png';
            link.download = fileName; 
            link.href = url;
            link.click();
        }

        function closeModal() {
            document.getElementById('successModal').classList.remove('active');
            showPage('member-login');
        }

        // Initialize
        window.onload = function() {
            // Memasang event listener untuk menangani balasan iframe setelah form submit
            // Ini adalah perbaikan untuk ReferenceError
            document.getElementById('hidden_iframe').onload = handleFormSubmit; 
            checkSession();
        }
    </script>
